  m_text: "<color=#FFD700>Rhythm Cafe</color>\n<color=#AAAAAA>\u8282\u594F\u533B\u751F\u8C31\u9762\u6D4F\u89C8\u5668</color>\n\n<color=#4FC3F7>\u4F7F\u7528\u8BF4\u660E</color>\n<color=#FFFFFF>\u2022
    \u5728\u641C\u7D22\u6846\u8F93\u5165\u5173\u952E\u8BCD\u641C\u7D22\u8C31\u9762\n\u2022
    \u70B9\u51FB <color=#66BB6A>\u4E0B\u8F7D</color> \u6309\u94AE\u4FDD\u5B58\u8C31\u9762\u5230\u672C\u5730\n\u2022
    \u70B9\u51FB <color=#42A5F5>\u6E38\u73A9</color> \u6309\u94AE\u76F4\u63A5\u5F00\u59CB\u6E38\u620F\n\u2022
    \u6EDA\u52A8\u5217\u8868\u81EA\u52A8\u52A0\u8F7D\u66F4\u591A\u8C31\u9762</color>\n\n<color=#4FC3F7>\u5F00\u53D1\u56E2\u961F</color>\n<color=#FF8A65>memsyslizi</color>
    <color=#AAAAAA>- \u4E3B\u7A0B\u5E8F\u5F00\u53D1</color>\n<color=#FF8A65>StArray</color>
    <color=#AAAAAA>- \u5165\u53E3\u53CA\u8F85\u52A9\u5F00\u53D1</color>\n\n<color=#4FC3F7>\u76F8\u5173\u94FE\u63A5</color>\n<color=#FFFFFF>\u5982\u679C\u60A8\u6709\u5174\u8DA3\uFF0C\u6B22\u8FCE\u8BBF\u95EE\uFF1A</color>\n<color=#42A5F5>\u539F\u7F51\u7AD9</color>
    <color=#AAAAAA>https://rhythm.cafe/</color>\n<color=#42A5F5>\u56FD\u5185\u4EE3\u7406</color>
    <color=#AAAAAA>https://cafe.rhythmdoctor.top/</color>\n\n<color=#666666>\u611F\u8C22\u4F7F\u7528
    Rhythm Cafe\uFF01</color>"
